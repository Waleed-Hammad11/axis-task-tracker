{
    "version": 2,
    "builds": [
        {
            "src": "src/app.js",
            "use": "@vercel/node"
        }
        ],
        "routes": [
        {
            "src": "/api/v1/tasks/(.*)",
            "dest": "src/app.js"
        },
        {
            "src": "/api/v1/tasks",
            "dest": "src/app.js"
        },
        {
            "src": "/(.*)",
            "dest": "src/app.js"
        }
        ]
}